---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const SITE_URL = "https://golfcartrentalthevillagesfl.com";
const DEFAULT_OG = "/cart-images/4-passenger-1.jpg";

const {
  title = "Golf Cart Rentals The Villages — The Gold Standard Since 1999",
  description = "Premium golf cart rentals in The Villages, Florida. 2, 4, and 6-passenger gas carts available weekly and monthly. Free delivery. Call (352) 306-4409.",
  ogImage = DEFAULT_OG,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageUrl = ogImage.startsWith("http") ? ogImage : new URL(ogImage, SITE_URL).toString();

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": SITE_URL + "/#business",
  name: "Golf Cart Rentals The Villages",
  alternateName: "GCR Villages",
  description: "Premium golf cart rentals in The Villages, Florida. 2, 4, and 6-passenger gas carts available weekly and monthly.",
  url: SITE_URL,
  telephone: "+1-352-306-4409",
  email: "villages@mastersgolfcars.com",
  image: SITE_URL + DEFAULT_OG,
  logo: SITE_URL + "/logo-villages.png",
  priceRange: "$$",
  foundingDate: "1999",
  address: {
    "@type": "PostalAddress",
    streetAddress: "624 Holly Cir",
    addressLocality: "Lady Lake",
    addressRegion: "FL",
    postalCode: "32159",
    addressCountry: "US",
  },
  areaServed: [
    { "@type": "Place", name: "The Villages, FL" },
    { "@type": "Place", name: "Lady Lake, FL" },
    { "@type": "Place", name: "Sumter County, FL" },
    { "@type": "Place", name: "Lake County, FL" },
    { "@type": "Place", name: "Marion County, FL" },
  ],
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      opens: "07:00",
      closes: "19:00",
    },
  ],
  sameAs: [
    "https://facebook.com/gcrvillages",
    "https://instagram.com/gcrvillages",
    "https://x.com/gcrvillages",
    "https://tiktok.com/@gcrvillages",
    "https://youtube.com/@gcrvillages",
    "https://pinterest.com/gcrvillages",
  ],
};
