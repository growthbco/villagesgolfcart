    <script is:inline>
      (function () {
        function initMobileMenu() {
          var btn = document.getElementById("mobile-menu-btn");
          var menu = document.getElementById("mobile-menu");
          if (!btn || !menu) return;
          var icon = btn.querySelector("i");
          var open = false;

          function setState(o) {
            open = o;
            if (open) {
              menu.classList.remove("-translate-y-full");
              menu.classList.add("translate-y-0");
              document.body.style.overflow = "hidden";
              if (icon) { icon.classList.remove("fa-bars"); icon.classList.add("fa-xmark"); }
            } else {
              menu.classList.remove("translate-y-0");
              menu.classList.add("-translate-y-full");
              document.body.style.overflow = "";
              if (icon) { icon.classList.remove("fa-xmark"); icon.classList.add("fa-bars"); }
            }
          }

          btn.addEventListener("click", function (e) {
            e.preventDefault();
            e.stopPropagation();
            setState(!open);
          });

          // Close menu when clicking any menu link
          menu.querySelectorAll("a[href]").forEach(function (a) {
            a.addEventListener("click", function () { setState(false); });
          });

          // Close on ESC
          document.addEventListener("keydown", function (e) {
            if (e.key === "Escape" && open) setState(false);
          });

          // Submenu toggles
          document.querySelectorAll("[data-mobile-toggle]").forEach(function (b) {
            b.addEventListener("click", function () {
              var key = b.getAttribute("data-mobile-toggle");
              var submenu = document.querySelector('[data-mobile-submenu="' + key + '"]');
              var chevron = document.querySelector('[data-chevron="' + key + '"]');
              if (submenu) submenu.classList.toggle("hidden");
              if (chevron) chevron.classList.toggle("rotate-180");
            });
          });
        }

        // Run immediately if DOM ready, else wait
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", initMobileMenu);
        } else {
          initMobileMenu();
        }
      })();
    </script>
  </body>
</html>
