---
import Layout from "../layouts/Layout.astro";
import QuoteForm from "../components/QuoteForm.astro";

const images = [
  { src: "/cart-images/4-passenger-1.jpg", alt: "4-Passenger Deluxe Gas Golf Cart Rental — Front 3/4 View", title: "Front 3/4 View", description: "Blue Yamaha 4-passenger gas golf cart with rear-facing back seat and tan canopy top — the most popular cart for families and groups in The Villages." },
  { src: "/cart-images/4-passenger-2.jpg", alt: "4-Passenger Deluxe Golf Cart — Front View", title: "Front View", description: "Clean front-on profile with windshield up — sized to fit comfortably down Villages neighborhood paths and town-square parking." },
  { src: "/cart-images/4-passenger-3.jpg", alt: "4-Passenger Deluxe Golf Cart — Side Profile Showing All Four Seats", title: "Side Profile", description: "Spacious front bench plus rear-facing back seat for four passengers, with cushioned tan seating throughout." },
];

const keyFeatures = [
  "4-passenger capacity with spacious seating",
  "Weather protection with side curtains",
  "Powerful gas engine for dependable performance",
  "Smooth performance and easy handling",
  "Long range for extended use",
];

const perfectFor = [
  "Retirement communities",
  "Neighborhoods and residential areas",
  "Equestrian events and competitions",
  "Weddings and special occasions",
  "Conferences and business events",
  "Festivals and outdoor events",
];

const useCases = [
  { icon: "fa-house-chimney", title: "Retirement Communities", body: "Perfect for comfortable transportation around retirement communities, offering weather protection and spacious seating." },
  { icon: "fa-horse", title: "Equestrian Events", body: "Ideal for horse shows, competitions, and equestrian events with reliable performance and weather protection." },
  { icon: "fa-heart", title: "Weddings & Events", body: "Great for weddings, conferences, and special occasions with elegant design and comfortable seating." },
];

const features = [
  { icon: "fa-cloud-rain", title: "Weather Protection", body: "Side curtains protect from rain and wind" },
  { icon: "fa-users", title: "Spacious Seating", body: "Comfortable seating for 4 passengers" },
  { icon: "fa-bolt", title: "Reliable Performance", body: "Powerful gas engine for dependable operation" },
  { icon: "fa-road", title: "Long Range", body: "Extended range for all-day use" },
];
---

<Layout title="4-Passenger Deluxe Golf Cart Rentals in The Villages | Golf Cart Rentals The Villages FL" description="Spacious 4-passenger gas golf cart rentals in The Villages. Weather-resistant side curtains, weekly and monthly rates. Call (352) 306-4409.">
  <!-- HERO -->
  <section class="relative py-24 lg:py-32 bg-slate-50 overflow-hidden">
    <div class="absolute top-20 right-20 w-64 h-64 bg-brand-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 -z-10"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-brand-50 rounded-bl-[100px] -z-10 hidden lg:block"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-block bg-brand-100 text-brand-700 text-xs font-bold px-3 py-1 rounded-full mb-4 border border-brand-200">Most Popular</div>
      <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-4">Deluxe 4-Passenger</p>
      <h1 class="font-heading font-black text-4xl sm:text-5xl lg:text-6xl text-slate-900 tracking-tight uppercase leading-[1.05] mb-6">
        4-Passenger Deluxe Golf Cart Rentals <br /><span class="text-brand-600 italic">in The Villages</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Stay comfortable in any season with this 4-passenger deluxe gas golf cart — ideal for rainy or cooler weather. Perfect for retirement communities, neighborhoods, equestrian events, weddings, conferences, and festivals in The Villages, Florida.
      </p>
    </div>
  </section>

  <!-- DETAILS -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="font-heading font-black text-3xl text-slate-900 uppercase mb-6">4-Passenger Deluxe Gas Golf Cart Rental</h2>
          <div class="bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 p-8 mb-8">
            <div class="text-center mb-8">
              <a href="tel:+13523064409" class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold py-3 px-6 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5">
                <i class="fa-solid fa-phone"></i> Call for Pricing
              </a>
              <p class="text-slate-600 text-sm mt-3">Available in weekly and monthly rentals</p>
            </div>
            <p class="text-slate-700 mb-6 leading-relaxed">
              Experience premium comfort and protection with our 4-passenger deluxe golf cart featuring weather-resistant side curtains and enhanced seating. Designed specifically for The Villages' diverse climate, this cart provides year-round reliability whether you're navigating retirement communities, attending equestrian events, or celebrating special occasions. The advanced gas engine delivers consistent power and extended range, making it perfect for all-day use at weddings, conferences, festivals, and neighborhood transportation throughout The Villages, Florida.
            </p>
            <h3 class="font-heading font-black text-lg text-slate-900 uppercase mb-4">Key Features</h3>
            <ul class="space-y-3">
              {keyFeatures.map((f) => (
                <li class="flex items-start gap-3">
                  <div class="w-6 h-6 rounded-full bg-brand-100 flex items-center justify-center text-brand-600 flex-shrink-0 mt-0.5"><i class="fa-solid fa-check text-xs"></i></div>
                  <span class="text-slate-700">{f}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="bg-brand-50 border border-brand-200 rounded-2xl p-8">
            <h3 class="font-heading font-black text-lg text-slate-900 uppercase mb-4">Perfect For</h3>
            <ul class="grid grid-cols-1 gap-2">
              {perfectFor.map((p) => (
                <li class="flex items-center gap-2 text-slate-700"><i class="fa-solid fa-circle-check text-brand-600"></i>{p}</li>
              ))}
            </ul>
          </div>
        </div>

        <div>
          <h2 class="font-heading font-black text-3xl text-slate-900 uppercase mb-6">4-Passenger Deluxe Gallery</h2>
          <div class="bg-white rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden relative">
            <div class="relative h-96 overflow-hidden bg-slate-100">
              <div class="absolute top-4 left-4 bg-brand-600 text-white px-3 py-1 rounded-full text-xs font-bold z-10 uppercase tracking-wide shadow-lg shadow-brand-500/30">Deluxe 4-Passenger</div>
              <img id="slideshow-main-deluxe4" class="w-full h-full object-cover transition-opacity duration-500" src={images[0].src} alt={images[0].alt} />
            </div>
            <button id="prev-btn-deluxe4" class="absolute left-4 top-48 -translate-y-1/2 bg-white/90 hover:bg-white text-brand-600 p-3 rounded-full shadow-lg z-10 w-10 h-10 flex items-center justify-center" aria-label="Previous"><i class="fa-solid fa-chevron-left"></i></button>
            <button id="next-btn-deluxe4" class="absolute right-4 top-48 -translate-y-1/2 bg-white/90 hover:bg-white text-brand-600 p-3 rounded-full shadow-lg z-10 w-10 h-10 flex items-center justify-center" aria-label="Next"><i class="fa-solid fa-chevron-right"></i></button>

            <div class="p-4 bg-slate-50 border-t border-slate-200">
              <div class="flex gap-2 overflow-x-auto justify-center" id="thumbnails-deluxe4">
                {images.map((img, i) => (
                  <button class={`flex-shrink-0 thumbnail-btn${i === 0 ? " active" : ""}`} data-index={i} aria-label={`Show image ${i + 1}`}>
                    <img class={`w-20 h-20 object-cover rounded-lg border-2 ${i === 0 ? "border-brand-600 opacity-100" : "border-transparent opacity-60 hover:opacity-80"}`} src={img.src} alt={`Thumbnail ${i + 1}`} />
                  </button>
                ))}
              </div>
            </div>

            <div class="p-6 border-t border-slate-200">
              <h3 class="font-heading font-bold text-slate-900 uppercase mb-2" id="image-title-deluxe4">{images[0].title}</h3>
              <p class="text-slate-600 text-sm leading-relaxed" id="image-desc-deluxe4">{images[0].description}</p>
            </div>
          </div>

          <div class="mt-6 bg-slate-50 rounded-2xl p-6 border border-slate-200">
            <h3 class="font-heading font-black text-lg text-slate-900 uppercase mb-4">Specifications</h3>
            <div class="grid grid-cols-2 gap-4 text-sm">
              <div class="bg-white p-4 rounded-xl border border-slate-100"><div class="font-bold text-slate-900">Capacity</div><div class="text-slate-600">4 passengers</div></div>
              <div class="bg-white p-4 rounded-xl border border-slate-100"><div class="font-bold text-slate-900">Engine</div><div class="text-slate-600">Gas-powered</div></div>
              <div class="bg-white p-4 rounded-xl border border-slate-100"><div class="font-bold text-slate-900">Top Speed</div><div class="text-slate-600">Up to 25 mph</div></div>
              <div class="bg-white p-4 rounded-xl border border-slate-100"><div class="font-bold text-slate-900">Range</div><div class="text-slate-600">150+ miles per tank</div></div>
              <div class="bg-white p-4 rounded-xl border border-slate-100"><div class="font-bold text-slate-900">Design</div><div class="text-slate-600">Weather-protected canopy</div></div>
              <div class="bg-white p-4 rounded-xl border border-slate-100"><div class="font-bold text-slate-900">Safety</div><div class="text-slate-600">Seat belts &amp; lights</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">All-Weather Transportation</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Perfect for Any Season</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
        <p class="text-slate-600 mt-6">Built for comfort and reliability in all weather conditions.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {useCases.map((uc) => (
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100">
            <div class="w-16 h-16 bg-brand-600 rounded-2xl flex items-center justify-center mb-6 shadow-lg shadow-brand-500/30">
              <i class={`fa-solid ${uc.icon} text-white text-2xl`}></i>
            </div>
            <h3 class="font-heading font-black text-xl text-slate-900 uppercase mb-3">{uc.title}</h3>
            <p class="text-slate-600 leading-relaxed">{uc.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Why Choose This Cart</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Why Choose Our Deluxe Golf Carts?</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
        <p class="text-slate-600 mt-6">Designed for comfort and reliability in any weather condition.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((f) => (
          <div class="text-center">
            <div class="w-20 h-20 bg-brand-600 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg shadow-brand-500/30">
              <i class={`fa-solid ${f.icon} text-white text-2xl`}></i>
            </div>
            <h3 class="font-heading font-bold text-slate-900 uppercase text-sm tracking-wide mb-2">{f.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RENTAL PERIODS -->
  <section class="py-24 bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Flexible Rentals</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Available Rental Periods</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
        <p class="text-slate-600 mt-6">Choose the rental period that works best for your event or project needs.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white rounded-3xl p-8 shadow-xl shadow-slate-200/50 border border-slate-100 text-center">
          <h3 class="font-heading font-black text-2xl text-slate-900 uppercase mb-2">Weekly</h3>
          <p class="text-slate-600 mb-6">Great value for extended events</p>
          <a href="/weekly-golf-cart-rental-villages" class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold py-3 px-6 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5">View Details <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        <div class="bg-white rounded-3xl p-8 shadow-xl shadow-slate-200/50 border border-slate-100 text-center">
          <h3 class="font-heading font-black text-2xl text-slate-900 uppercase mb-2">Monthly</h3>
          <p class="text-slate-600 mb-6">Best rates for long-term projects</p>
          <a href="/monthly-golf-cart-rental-villages" class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold py-3 px-6 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5">View Details <i class="fa-solid fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-slate-900 text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-500 rounded-full mix-blend-soft-light filter blur-3xl opacity-30"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-black text-3xl md:text-5xl text-white uppercase mb-6 leading-tight">Rent a 4-Passenger Deluxe Golf Cart in The Villages Today</h2>
      <p class="text-xl text-slate-300 mb-10">Premium 4-passenger deluxe golf carts with weather protection and comfortable seating. Perfect for year-round transportation in The Villages, Florida. Available in weekly and monthly rentals. Call us for availability and competitive pricing.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="tel:+13523064409" class="inline-flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold py-4 px-8 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5"><i class="fa-solid fa-phone"></i> Call (352) 306-4409</a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-100 text-slate-900 font-bold py-4 px-8 rounded-lg shadow-lg transition-all"><i class="fa-solid fa-envelope"></i> Send Message</a>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ images }}>
    document.addEventListener("DOMContentLoaded", function () {
      let currentSlide = 0;
      const mainImg = document.getElementById("slideshow-main-deluxe4");
      const titleEl = document.getElementById("image-title-deluxe4");
      const descEl = document.getElementById("image-desc-deluxe4");
      const thumbnails = document.querySelectorAll("#thumbnails-deluxe4 .thumbnail-btn");
      function updateSlide(index) {
        currentSlide = index;
        const image = images[currentSlide];
        if (mainImg) { mainImg.src = image.src; mainImg.alt = image.alt; }
        if (titleEl) titleEl.textContent = image.title;
        if (descEl) descEl.textContent = image.description;
        thumbnails.forEach((btn, i) => {
          const img = btn.querySelector("img");
          if (!img) return;
          if (i === currentSlide) { btn.classList.add("active"); img.classList.remove("border-transparent","opacity-60"); img.classList.add("border-brand-600","opacity-100"); }
          else { btn.classList.remove("active"); img.classList.remove("border-brand-600","opacity-100"); img.classList.add("border-transparent","opacity-60"); }
        });
      }
      document.getElementById("next-btn-deluxe4")?.addEventListener("click", () => updateSlide((currentSlide + 1) % images.length));
      document.getElementById("prev-btn-deluxe4")?.addEventListener("click", () => updateSlide((currentSlide - 1 + images.length) % images.length));
      thumbnails.forEach((btn, index) => btn.addEventListener("click", () => updateSlide(index)));
    });
  </script>

  <!-- EXPLORE MORE CARTS -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Compare Options</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Explore More Cart Options</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <a href="/2-passenger-deluxe-golf-cart" class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100 hover:-translate-y-1 transition-transform">
          <div class="h-48 bg-slate-100 overflow-hidden"><img src="/cart-images/2-passenger-1.jpg" alt="2-Passenger Deluxe" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" /></div>
          <div class="p-5">
            <h3 class="font-heading font-bold text-slate-900 uppercase text-sm mb-1">2-Passenger Deluxe</h3>
            <p class="text-slate-600 text-sm">Compact pick for couples and easy parking.</p>
          </div>
        </a>
        <a href="/6-passenger-golf-cart" class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100 hover:-translate-y-1 transition-transform">
          <div class="h-48 bg-slate-100 overflow-hidden"><img src="/cart-images/6-passenger-1.jpg" alt="6-Passenger" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" /></div>
          <div class="p-5">
            <h3 class="font-heading font-bold text-slate-900 uppercase text-sm mb-1">6-Passenger</h3>
            <p class="text-slate-600 text-sm">Maximum capacity for wedding parties and groups.</p>
          </div>
        </a>
        <a href="/weekly-golf-cart-rental-villages" class="group bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100 hover:-translate-y-1 transition-transform">
          <div class="h-48 bg-brand-50 flex items-center justify-center"><i class="fa-solid fa-calendar-week text-brand-600 text-6xl"></i></div>
          <div class="p-5">
            <h3 class="font-heading font-bold text-slate-900 uppercase text-sm mb-1">Weekly &amp; Monthly</h3>
            <p class="text-slate-600 text-sm">See rental period options and pricing structure.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <QuoteForm formName="quote-4pass" hiddenContext={{ "source-page": "4-passenger-deluxe", "cart-interest": "4-Passenger Deluxe" }} />
</Layout>
