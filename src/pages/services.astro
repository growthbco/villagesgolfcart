---
import Layout from "../layouts/Layout.astro";
import QuoteForm from "../components/QuoteForm.astro";

const coreServices = [
  { title: "2-Passenger", href: "/2-passenger-deluxe-golf-cart", img: "/cart-images/2-passenger-1.jpg", blurb: "Perfect for couples and solo adventures. Compact, efficient, and easy to maneuver through all Villages locations.", badge: null, features: ["Compact design", "Easy parking", "Fuel efficient", "Perfect for shopping"] },
  { title: "4-Passenger", href: "/4-passenger-deluxe-golf-cart", img: "/cart-images/4-passenger-1.jpg", blurb: "Our most popular choice! Ideal for families and small groups. Comfortable seating with room for groceries and golf clubs.", badge: "Most Popular", features: ["Family friendly", "Extra storage space", "Golf club holders", "Comfortable seating"] },
  { title: "6-Passenger", href: "/6-passenger-golf-cart", img: "/cart-images/6-passenger-1.jpg", blurb: "Perfect for group adventures! Spacious design ideal for family outings, golf foursomes, or social gatherings.", badge: null, features: ["Group transportation", "Maximum comfort", "Ample storage", "Social seating"] },
];

const additionalServices = [
  { icon: "fa-truck-fast", title: "Free Delivery", body: "We deliver to all Villages locations at no extra cost. Your cart will be waiting when you arrive!" },
  { icon: "fa-clock", title: "Flexible Pickup", body: "Early morning or late evening pickup available. We work around your schedule." },
  { icon: "fa-shield-halved", title: "Insurance Included", body: "Comprehensive coverage included with every rental. Drive with peace of mind." },
  { icon: "fa-headset", title: "24/7 Support", body: "Emergency support available anytime. We're here when you need us." },
  { icon: "fa-map-location-dot", title: "Villages Guide", body: "Free map and guide to The Villages included with every rental." },
  { icon: "fa-wrench", title: "Maintenance", body: "All carts maintained to the highest standards. Clean, safe, and reliable." },
  { icon: "fa-credit-card", title: "Easy Payment", body: "Multiple payment options available. Cash, credit card, or check accepted." },
  { icon: "fa-heart", title: "Personal Touch", body: "We remember your preferences and treat you like family." },
];
---

<Layout title="Our Services — Golf Cart Rentals The Villages FL" description="Weekly and monthly golf cart rentals in The Villages. 2, 4, and 6-passenger carts, free delivery, insurance included, 24/7 support.">
  <!-- HERO -->
  <section class="relative py-24 lg:py-32 bg-slate-50 overflow-hidden">
    <div class="absolute top-20 right-20 w-64 h-64 bg-brand-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 -z-10"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-brand-50 rounded-bl-[100px] -z-10 hidden lg:block"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-4">Our Services</p>
      <h1 class="font-heading font-black text-4xl sm:text-5xl lg:text-6xl text-slate-900 tracking-tight uppercase leading-[1.05] mb-6">
        Flexible Rentals, <span class="text-brand-600 italic">Personal Touch</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed">
        From quick weekend getaways to extended monthly rentals, we offer flexible solutions that fit your lifestyle and budget. Every service includes our signature personal touch.
      </p>
    </div>
  </section>

  <!-- CORE SERVICES -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Core Rentals</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Choose Your Cart</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {coreServices.map((s) => (
          <div class="bg-white rounded-3xl overflow-hidden shadow-xl shadow-slate-200/50 flex flex-col group relative">
            {s.badge && (
              <span class="absolute top-4 left-4 z-20 bg-brand-100 text-brand-700 text-xs font-bold px-3 py-1 rounded-full border border-brand-200">{s.badge}</span>
            )}
            <div class="h-64 bg-slate-100 overflow-hidden">
              <img src={s.img} alt={s.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-8 flex flex-col flex-1">
              <h3 class="font-heading font-black text-2xl text-slate-900 uppercase mb-3">{s.title}</h3>
              <p class="text-slate-600 mb-5 leading-relaxed">{s.blurb}</p>
              <ul class="space-y-2 mb-6">
                {s.features.map((f) => (
                  <li class="flex items-start gap-2">
                    <div class="w-5 h-5 rounded-full bg-brand-100 flex items-center justify-center text-brand-600 flex-shrink-0 mt-0.5"><i class="fa-solid fa-check text-[10px]"></i></div>
                    <span class="text-slate-700 text-sm">{f}</span>
                  </li>
                ))}
              </ul>
              <a href={s.href} class="mt-auto inline-flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold py-3 px-6 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5">View Details <i class="fa-solid fa-arrow-right"></i></a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ADDITIONAL SERVICES -->
  <section class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Above &amp; Beyond</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Additional Services</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {additionalServices.map((svc) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="w-14 h-14 bg-brand-50 rounded-xl flex items-center justify-center mb-4 text-brand-600 text-xl">
              <i class={`fa-solid ${svc.icon}`}></i>
            </div>
            <h3 class="font-heading font-bold text-slate-900 uppercase mb-2 text-sm tracking-wide">{svc.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{svc.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SPECIAL PACKAGES -->
  <section class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Special Deals</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Packages &amp; Discounts</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white rounded-3xl p-10 shadow-xl shadow-slate-200/50 border border-slate-100">
          <div class="inline-block bg-brand-100 text-brand-700 text-xs font-bold px-3 py-1 rounded-full mb-4 border border-brand-200">First-Time Customer</div>
          <h3 class="font-heading font-black text-2xl text-slate-900 uppercase mb-3">10% Off Your First Rental</h3>
          <p class="text-slate-600 mb-5">Welcome to The Villages! Save on your first booking.</p>
          <ul class="space-y-3 mb-5">
            <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-600"></i><span class="text-slate-700">10% discount on first rental</span></li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-600"></i><span class="text-slate-700">Free Villages guidebook</span></li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-600"></i><span class="text-slate-700">Priority booking for future rentals</span></li>
          </ul>
          <p class="text-sm text-brand-700 font-bold">Just mention "First Time" when booking!</p>
        </div>
        <div class="bg-white rounded-3xl p-10 shadow-xl shadow-slate-200/50 border border-slate-100">
          <div class="inline-block bg-brand-100 text-brand-700 text-xs font-bold px-3 py-1 rounded-full mb-4 border border-brand-200">Group Discount</div>
          <h3 class="font-heading font-black text-2xl text-slate-900 uppercase mb-3">Rent Multiple, Save Big</h3>
          <p class="text-slate-600 mb-5">Perfect for family reunions and group events.</p>
          <ul class="space-y-3 mb-5">
            <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-600"></i><span class="text-slate-700">2–3 carts: 15% off total</span></li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-600"></i><span class="text-slate-700">4+ carts: 20% off total</span></li>
            <li class="flex items-center gap-2"><i class="fa-solid fa-check text-brand-600"></i><span class="text-slate-700">Perfect for family reunions</span></li>
          </ul>
          <p class="text-sm text-brand-700 font-bold">Great for family gatherings!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-slate-900 text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-500 rounded-full mix-blend-soft-light filter blur-3xl opacity-30"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-black text-3xl md:text-5xl text-white uppercase mb-6 leading-tight">Ready to Roll?</h2>
      <p class="text-xl text-slate-300 mb-10">Get your custom quote today and discover why thousands of Villages residents choose us.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold py-4 px-8 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5">Get Your Quote Now</a>
        <a href="tel:+13523064409" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-100 text-slate-900 font-bold py-4 px-8 rounded-lg shadow-lg transition-all"><i class="fa-solid fa-phone"></i> Call (352) 306-4409</a>
      </div>
    </div>
  </section>

  <QuoteForm formName="quote-services" hiddenContext={{ "source-page": "services" }} />
</Layout>
