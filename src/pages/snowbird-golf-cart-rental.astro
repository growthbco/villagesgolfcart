---
import Layout from "../layouts/Layout.astro";
import QuoteForm from "../components/QuoteForm.astro";

const benefits = [
  { icon: "fa-snowflake", title: "Built for Snowbirds", body: "Hundreds of seasonal residents trust us every winter - we know the routine." },
  { icon: "fa-truck-fast", title: "Pre-Arrival Delivery", body: "Cart waiting at your door the day you fly down - no setup hassle." },
  { icon: "fa-piggy-bank", title: "Best Seasonal Rates", body: "Multi-month discounts that make seasonal renting beat owning a cart." },
  { icon: "fa-headset", title: "We Handle Everything", body: "Maintenance, insurance, charging, and roadside - all included." },
];

const stages = [
  { icon: "fa-plane-arrival", title: "Before You Arrive", body: "Lock in your dates and cart by phone or form. We&rsquo;ll coordinate delivery to be waiting on arrival day." },
  { icon: "fa-house", title: "During Your Stay", body: "Drive freely throughout The Villages. Any issues? One call - we handle it." },
  { icon: "fa-plane-departure", title: "Departure Day", body: "Just leave the cart. We pick up after your flight. Same easy process next season." },
];
---
<Layout
  title="Snowbird Golf Cart Rentals in The Villages, FL | GCR Villages"
  description="Snowbird golf cart rentals in The Villages, FL. Seasonal rates for 3-6 month winter stays. Cart waiting on arrival, maintenance and insurance included. Call (352) 306-4409."
>
  <section class="relative py-24 lg:py-32 bg-slate-50 overflow-hidden">
    <div class="absolute top-20 right-20 w-64 h-64 bg-brand-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 -z-10"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-brand-50 rounded-bl-[100px] -z-10 hidden lg:block"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-4">Snowbirds Welcome</p>
      <h1 class="font-heading font-black text-4xl sm:text-5xl lg:text-6xl text-slate-900 tracking-tight uppercase leading-[1.05] mb-6">
        Snowbird Golf Cart <span class="text-brand-600 italic">Rentals</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Spending your winter in The Villages? We&rsquo;ve been the snowbird favorite since 1999 - seasonal multi-month rates, cart waiting on arrival day, everything included. The smart alternative to buying a cart you only use part of the year.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mt-10">
        <a href="#quote" class="inline-flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold py-4 px-8 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5"><i class="fa-solid fa-bolt"></i> Reserve Your Season</a>
        <a href="tel:+13523064409" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-100 text-slate-900 font-bold py-4 px-8 rounded-lg shadow-lg transition-all"><i class="fa-solid fa-phone"></i> (352) 306-4409</a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Why Snowbirds Pick Us</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Built for the Season</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {benefits.map((b) => (
          <div class="bg-slate-50 rounded-2xl p-6 text-center">
            <div class="w-16 h-16 bg-brand-600 rounded-2xl flex items-center justify-center text-white text-2xl mx-auto mb-5"><i class={`fa-solid ${b.icon}`}></i></div>
            <h3 class="font-heading font-bold text-slate-900 uppercase mb-2 text-sm tracking-wide">{b.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">How It Works</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Your Season, Handled</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {stages.map((s, i) => (
          <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 text-center">
            <div class="w-12 h-12 bg-brand-100 text-brand-700 rounded-full flex items-center justify-center mx-auto mb-4 font-heading font-black text-lg">{i + 1}</div>
            <div class="text-brand-600 text-2xl mb-3"><i class={`fa-solid ${s.icon}`}></i></div>
            <h3 class="font-heading font-bold text-slate-900 uppercase mb-2 text-sm tracking-wide">{s.title}</h3>
            <p class="text-slate-600 text-sm">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-3">Popular Seasons</p>
      <h2 class="font-heading font-black text-2xl sm:text-3xl text-slate-900 uppercase mb-6">Typical Snowbird Stays</h2>
      <div class="flex flex-wrap justify-center gap-3">
        <span class="inline-flex items-center gap-2 bg-brand-50 border border-brand-200 text-brand-700 font-semibold px-5 py-3 rounded-full"><i class="fa-solid fa-snowflake"></i> Nov – Mar (5 months)</span>
        <span class="inline-flex items-center gap-2 bg-brand-50 border border-brand-200 text-brand-700 font-semibold px-5 py-3 rounded-full"><i class="fa-solid fa-snowflake"></i> Dec – Mar (4 months)</span>
        <span class="inline-flex items-center gap-2 bg-brand-50 border border-brand-200 text-brand-700 font-semibold px-5 py-3 rounded-full"><i class="fa-solid fa-snowflake"></i> Jan – Mar (3 months)</span>
        <span class="inline-flex items-center gap-2 bg-brand-50 border border-brand-200 text-brand-700 font-semibold px-5 py-3 rounded-full"><i class="fa-solid fa-snowflake"></i> Feb – Apr (3 months)</span>
      </div>
    </div>
  </section>

  <QuoteForm formName="quote-snowbird" hiddenContext={{ "source-page": "snowbird", "rental-term": "seasonal" }} id="quote" />
</Layout>
