    "Same-day delivery throughout Lady Lake",
    "Direct cart-path access to Spanish Springs",
    "Weekly and monthly rentals — built for visitors and locals",
    "2, 4, and 6-passenger gas carts available",
    "Insurance and roadside included",
    "We're locals — based right here in Lady Lake",
  ]}
  landmarks={[
    { title: "Spanish Springs Town Square", body: "Live music, restaurants, and shops in the heart of Lady Lake.", icon: "fa-music" },
    { title: "Lake Griffin State Park", body: "Fishing pier, boat ramp, and scenic boardwalks.", icon: "fa-water" },
    { title: "Saddlebrook & Hacienda Hills", body: "Championship golf courses minutes by cart.", icon: "fa-golf-ball-tee" },
