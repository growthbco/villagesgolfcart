  ]}
  landmarks={[
    { title: "Spanish Springs Town Square", body: "Live music nightly, restaurants, shops, and the iconic Katie Belle's. The square is fully cart-accessible.", icon: "fa-music" },
    { title: "Paddock Square Restaurants", body: "Dozens of dining options within easy cart distance, from casual to upscale.", icon: "fa-utensils" },
