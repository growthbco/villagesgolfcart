---
import Layout from "../layouts/Layout.astro";

const fleet = [
  { title: "2-Passenger", href: "/2-passenger-deluxe-golf-cart", img: "/cart-images/2-passenger-1.jpg", blurb: "Perfect for couples", badge: null },
  { title: "4-Passenger", href: "/4-passenger-deluxe-golf-cart", img: "/cart-images/4-passenger-1.jpg", blurb: "Most popular choice", badge: "Most Popular" },
  { title: "6-Passenger", href: "/6-passenger-golf-cart", img: "/cart-images/6-passenger-1.jpg", blurb: "Great for groups", badge: null },
];

const coreBenefits = [
  { icon: "fa-star", title: "Premium Fleet", body: "Well-maintained and reliable carts ready for your week." },
  { icon: "fa-shield-halved", title: "Quality Carts", body: "Clean, safe vehicles inspected before every delivery." },
  { icon: "fa-medal", title: "Professional Service", body: "Serving The Villages since 1999 with thousands of happy renters." },
  { icon: "fa-map-location-dot", title: "Villages Ready", body: "Outfitted for The Villages lifestyle — cart paths, town squares, and beyond." },
];

const whyChoose = [
  { icon: "fa-calendar-week", title: "Week-Long Value", body: "Seven days gives you the perfect amount of time to explore The Villages without feeling rushed." },
  { icon: "fa-piggy-bank", title: "Great Value", body: "Get the convenience of a full week rental with all maintenance included at a great value." },
  { icon: "fa-circle-check", title: "Full Service Included", body: "Weekly rentals include fuel, full maintenance service, and roadside assistance. No hidden costs or surprises." },
];

const perfectFor = [
  { icon: "fa-people-roof", title: "Family Vacations", body: "A cart for the family while you visit grandparents or vacation together." },
  { icon: "fa-people-group", title: "Group Trips", body: "Friend reunions, milestone birthdays, golf weekends, and bachelorette getaways." },
  { icon: "fa-briefcase", title: "Extended Business", body: "Conventions, training trips, and corporate stays that run 5–10 days." },
  { icon: "fa-champagne-glasses", title: "Special Occasions", body: "Weddings, anniversaries, and family reunions where everyone needs a ride." },
];

const included = [
  { heading: "Maintenance &amp; Service", icon: "fa-wrench", items: [
    "Pre-delivery safety inspection",
    "Fuel system check & service",
    "Tire pressure checks",
    "Brake adjustments",
    "Emergency roadside assistance",
  ]},
  { heading: "Fuel &amp; Coverage", icon: "fa-gas-pump", items: [
    "Full tank of gas at delivery",
    "No mileage surcharges",
    "Comprehensive insurance",
    "No deposit on most rentals",
    "Free delivery and pickup",
  ]},
  { heading: "Support", icon: "fa-headset", items: [
    "7-days-a-week customer line",
    "Same-day replacement if needed",
    "Free Villages map and guide",
    "Personal account manager",
    "Drop-off as late as 7 PM",
  ]},
  { heading: "Extras", icon: "fa-star", items: [
    "Cup holders &amp; storage",
    "Weather-resistant canopy",
    "Cart cover for overnight",
    "Charger / fuel can if needed",
    "Flexible pickup &amp; delivery",
  ]},
];
---
<Layout
  title="Weekly Golf Cart Rentals in The Villages, FL — Extended Vacation Value | GCR Villages"
  description="Weekly golf cart rentals in The Villages, FL. Perfect for week-long stays, family vacations, and groups. All maintenance and insurance included. Call (352) 306-4409."
>
  <!-- HERO -->
  <section class="relative py-24 lg:py-32 bg-slate-50 overflow-hidden">
    <div class="absolute top-20 right-20 w-64 h-64 bg-brand-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 -z-10"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-brand-50 rounded-bl-[100px] -z-10 hidden lg:block"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-4">Weekly Rentals</p>
      <h1 class="font-heading font-black text-4xl sm:text-5xl lg:text-6xl text-slate-900 tracking-tight uppercase leading-[1.05] mb-6">
        Weekly Golf Cart Rentals <span class="text-brand-600 italic">Extended Vacation Value</span>
      </h1>
      <p class="text-lg sm:text-xl text-slate-700 max-w-3xl mx-auto font-semibold mb-3">Perfect for Week-Long Stays</p>
      <p class="text-base sm:text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Planning a week-long vacation in The Villages? Our weekly rentals offer unbeatable value for extended stays, family vacations, and anyone staying 7+ days. Free delivery, insurance, and full maintenance included.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4 mt-10">
        <a href="#quote" class="inline-flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold py-4 px-8 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5">
          <i class="fa-solid fa-bolt"></i> Get a Weekly Quote
        </a>
        <a href="tel:+13523064409" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-100 text-slate-900 font-bold py-4 px-8 rounded-lg shadow-lg transition-all">
          <i class="fa-solid fa-phone"></i> (352) 306-4409
        </a>
      </div>
    </div>
  </section>

  <!-- FLEET -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Choose Your Cart</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Available Weekly</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {fleet.map((f) => (
          <a href={f.href} class="group bg-white rounded-3xl overflow-hidden shadow-xl shadow-slate-200/50 hover:-translate-y-1 transition-transform relative">
            {f.badge && <span class="absolute top-4 left-4 z-20 bg-brand-100 text-brand-700 text-xs font-bold px-3 py-1 rounded-full border border-brand-200">{f.badge}</span>}
            <div class="h-56 bg-slate-100 overflow-hidden">
              <img src={f.img} alt={f.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-6">
              <h3 class="font-heading font-black text-xl text-slate-900 uppercase mb-2">{f.title}</h3>
              <p class="text-slate-600 text-sm mb-4">{f.blurb}</p>
              <span class="inline-flex items-center gap-1 text-brand-600 font-bold text-sm">View Details <i class="fa-solid fa-arrow-right"></i></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CORE BENEFITS -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Premium Fleet</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">What You Get</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {coreBenefits.map((b) => (
          <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-100">
            <div class="w-14 h-14 bg-brand-50 rounded-xl flex items-center justify-center mb-4 text-brand-600 text-xl"><i class={`fa-solid ${b.icon}`}></i></div>
            <h3 class="font-heading font-bold text-slate-900 uppercase mb-2 text-sm tracking-wide">{b.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE WEEKLY -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Why Weekly</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Why Choose Weekly Rentals?</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {whyChoose.map((w) => (
          <div class="bg-slate-50 rounded-2xl p-8 text-center">
            <div class="w-16 h-16 bg-brand-600 rounded-2xl flex items-center justify-center text-white text-2xl mx-auto mb-5"><i class={`fa-solid ${w.icon}`}></i></div>
            <h3 class="font-heading font-bold text-slate-900 uppercase mb-3">{w.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{w.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PERFECT FOR -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Best For</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Perfect For</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {perfectFor.map((p) => (
          <div class="bg-white rounded-2xl p-6 text-center shadow-sm border border-slate-100">
            <div class="w-14 h-14 bg-brand-50 rounded-xl flex items-center justify-center mx-auto mb-4 text-brand-600 text-xl"><i class={`fa-solid ${p.icon}`}></i></div>
            <h3 class="font-heading font-bold text-slate-900 uppercase mb-2 text-sm tracking-wide">{p.title}</h3>
            <p class="text-slate-600 text-sm">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">All-Inclusive</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">What&rsquo;s Included in Your Weekly Rental</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {included.map((g) => (
          <div class="bg-slate-50 rounded-2xl p-6">
            <h3 class="font-heading font-bold text-brand-700 uppercase mb-4 text-sm tracking-wide flex items-center gap-2" set:html={`<i class='fa-solid ${g.icon}'></i> ${g.heading}`}></h3>
            <ul class="space-y-2">
              {g.items.map((i) => (
                <li class="flex items-start gap-2"><i class="fa-solid fa-check text-brand-600 mt-1 text-xs"></i><span class="text-slate-700 text-sm" set:html={i}></span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMPARE -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-3">Staying Longer?</p>
      <h2 class="font-heading font-black text-2xl sm:text-3xl text-slate-900 uppercase mb-4">Monthly Could Save You More</h2>
      <p class="text-slate-600 mb-6">Staying 30+ days? Monthly rentals give you priority service, all utilities, and even better per-day pricing.</p>
      <a href="/monthly-golf-cart-rental-villages" class="inline-flex items-center gap-2 bg-white hover:bg-slate-100 border border-slate-200 text-slate-900 font-bold py-3 px-6 rounded-lg transition-all">See Monthly Rates <i class="fa-solid fa-arrow-right"></i></a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-slate-900 text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-500 rounded-full mix-blend-soft-light filter blur-3xl opacity-30"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-black text-3xl md:text-5xl text-white uppercase mb-6 leading-tight">Ready to Reserve for the Week?</h2>
      <p class="text-xl text-slate-300 mb-10">Send your dates and delivery address — we&rsquo;ll quote you back the same day.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="#quote" class="inline-flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold py-4 px-8 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5">Get a Weekly Quote</a>
        <a href="tel:+13523064409" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-100 text-slate-900 font-bold py-4 px-8 rounded-lg shadow-lg transition-all"><i class="fa-solid fa-phone"></i> (352) 306-4409</a>
      </div>
    </div>
  </section>

  <!-- INLINE FORM -->
  <section id="quote" class="py-20 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Get In Touch</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Get Your Weekly Quote</h2>
        <p class="text-slate-600 mt-4">Fill out the form below and we&rsquo;ll get back to you within 2 hours!</p>
      </div>
      <div class="bg-slate-50 rounded-3xl shadow-xl p-8">
        <form name="quote-weekly" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="space-y-4">
          <input type="hidden" name="form-name" value="quote-weekly" />
          <input type="hidden" name="rental-term" value="weekly" />
          <p class="hidden"><label>Don&rsquo;t fill this out: <input name="bot-field" /></label></p>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-1">Name <span class="text-brand-600">*</span></label>
              <input type="text" name="name" required class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-1">Phone <span class="text-brand-600">*</span></label>
              <input type="tel" name="phone" required class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-700 mb-1">Email</label>
            <input type="email" name="email" class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all" />
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-700 mb-1">Delivery Address in The Villages</label>
            <input type="text" name="delivery-address" class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all" />
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-1">Rental Dates</label>
              <input type="text" name="rental-dates" placeholder="e.g. Jan 5 – Jan 12" class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-bold text-slate-700 mb-1">Cart Type</label>
              <select name="cart-type" class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all">
                <option value="">Not sure yet</option>
                <option value="2-passenger">2-Passenger Deluxe</option>
                <option value="4-passenger">4-Passenger Deluxe</option>
                <option value="6-passenger">6-Passenger</option>
              </select>
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-slate-700 mb-1">Message</label>
            <textarea name="message" rows="3" class="w-full px-4 py-3 rounded-lg bg-white border border-slate-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-200 outline-none transition-all"></textarea>
          </div>

          <label class="flex items-start gap-2 text-xs text-slate-600">
            <input type="checkbox" name="sms-consent" class="mt-0.5" />
            <span>I agree to receive text messages for booking and follow-up. Reply STOP to opt out.</span>
          </label>

          <button type="submit" class="w-full bg-brand-600 hover:bg-brand-700 text-white font-bold py-4 px-6 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5 flex justify-center items-center gap-2">
            <i class="fa-solid fa-bolt"></i> Get My Quote
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
