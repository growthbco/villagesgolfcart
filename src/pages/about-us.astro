---
import Layout from "../layouts/Layout.astro";
import QuoteForm from "../components/QuoteForm.astro";

const features = [
  { icon: "fa-award", title: "25+ Years Experience", body: "Serving The Villages since 1999 with unmatched local knowledge and expertise." },
  { icon: "fa-truck-fast", title: "Free Delivery", body: "We deliver to all Villages locations at no extra cost. Right to your door." },
  { icon: "fa-wrench", title: "Well Maintained", body: "Every golf cart is cleaned, inspected, and maintained to the highest standards." },
  { icon: "fa-headset", title: "24/7 Support", body: "Call us anytime at (352) 306-4409 for immediate assistance and support." },
];

const fleet = [
  { title: "2-Passenger", body: "Perfect for couples exploring The Villages. Comfortable, efficient, and easy to maneuver." },
  { title: "4-Passenger", body: "Most popular choice for families and small groups. Spacious and comfortable for all passengers." },
  { title: "6-Passenger", body: "Ideal for larger groups and family gatherings. Maximum capacity with comfort and style." },
];

const serviceAreas = [
  "Spanish Springs", "Lake Sumter Landing", "Brownwood Paddock Square",
  "Lady Lake", "Sumter Landing", "All Villages Areas",
];
---

<Layout title="About Us - Golf Cart Rentals The Villages FL" description="Family-owned golf cart rental business serving The Villages since 1999. 50+ premium golf carts throughout The Villages and surrounding areas.">
  <!-- HERO -->
  <section class="relative py-24 lg:py-32 bg-slate-50 overflow-hidden">
    <div class="absolute top-20 right-20 w-64 h-64 bg-brand-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 -z-10"></div>
    <div class="absolute top-0 right-0 w-1/2 h-full bg-brand-50 rounded-bl-[100px] -z-10 hidden lg:block"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-4">About Us</p>
      <h1 class="font-heading font-black text-4xl sm:text-5xl lg:text-6xl text-slate-900 tracking-tight uppercase leading-[1.05] mb-6">
        Family Owned <span class="text-brand-600 italic">Since 1999</span>
      </h1>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed">
        Professional golf cart rental service serving The Villages since 1999. Family-owned business with 50+ premium golf carts available throughout The Villages, Lady Lake, and surrounding areas.
      </p>
    </div>
  </section>

  <!-- FLEET -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Our Fleet</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Premium Golf Carts</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
        <p class="text-slate-600 mt-6">Well-maintained, clean, and reliable golf carts for every need.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {fleet.map((cart) => (
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 hover:shadow-xl transition-shadow">
            <div class="w-16 h-16 bg-brand-100 rounded-2xl flex items-center justify-center mb-6">
              <i class="fa-solid fa-car-side text-brand-600 text-2xl"></i>
            </div>
            <h3 class="font-heading font-black text-xl text-slate-900 uppercase mb-3">{cart.title}</h3>
            <p class="text-slate-600 leading-relaxed">{cart.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Why Choose Us</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Professional Service, Local Expertise</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((f) => (
          <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100 text-center">
            <div class="w-20 h-20 bg-brand-600 rounded-full flex items-center justify-center mx-auto mb-5 shadow-lg shadow-brand-500/30">
              <i class={`fa-solid ${f.icon} text-white text-2xl`}></i>
            </div>
            <h3 class="font-heading font-black text-base text-slate-900 uppercase mb-2">{f.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="py-24 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <p class="text-brand-600 font-bold tracking-widest uppercase text-sm mb-2">Service Area</p>
        <h2 class="font-heading font-black text-3xl sm:text-4xl text-slate-900 uppercase">Serving All Villages</h2>
        <div class="w-24 h-1 bg-brand-500 mx-auto mt-6"></div>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 max-w-3xl mx-auto">
        {serviceAreas.map((area) => (
          <div class="bg-slate-50 border border-slate-200 rounded-xl px-6 py-4 flex items-center">
            <i class="fa-solid fa-location-dot text-brand-500 mr-3"></i>
            <span class="font-bold text-slate-900">{area}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-slate-900 text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-500 rounded-full mix-blend-soft-light filter blur-3xl opacity-30"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-black text-3xl md:text-5xl text-white uppercase mb-6 leading-tight">Ready to Rent Your Cart?</h2>
      <p class="text-xl text-slate-300 mb-10">Join thousands of satisfied customers who trust us for their golf cart rental needs.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/pricing" class="inline-flex items-center justify-center gap-2 bg-brand-600 hover:bg-brand-700 text-white font-bold py-4 px-8 rounded-lg shadow-lg shadow-brand-500/30 transition-all transform hover:-translate-y-0.5">View Pricing &amp; Book Now</a>
        <a href="tel:+13523064409" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-100 text-slate-900 font-bold py-4 px-8 rounded-lg shadow-lg transition-all"><i class="fa-solid fa-phone"></i> Call (352) 306-4409</a>
      </div>
    </div>
  </section>

  <QuoteForm formName="quote-about" hiddenContext={{ "source-page": "about-us" }} />
</Layout>
